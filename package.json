{
  "name": "taskscore",
  "version": "0.1.0",
  "private": true,
  "description": "Hanggliding/paragliding competition track log analysis",
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '@taskscore/pages' dev",
    "build": "bun run --filter '@taskscore/pages' build",
    "deploy": "bun run --filter '@taskscore/pages' deploy",
    "deploy:worker": "bun run --filter airscore-api deploy",
    "deploy:all": "bun run deploy && bun run deploy:worker",
    "deployments": "wrangler pages deployment list --project-name=taskscore --json | jq .",
    "typecheck": "tsc --noEmit",
    "typecheck:analysis": "tsc --noEmit -p packages/analysis/tsconfig.json",
    "typecheck:worker": "bun run --filter airscore-api typecheck",
    "typecheck:all": "bun run typecheck && bun run typecheck:analysis && bun run typecheck:worker",
    "test": "bun test",
    "get-xcontest-task": "tsx scripts/get-xcontest-task.ts"
  },
  "workspaces": [
    "packages/*",
    "pages",
    "workers/*"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260109.0",
    "@types/bun": "^1.2.13",
    "@types/node": "^25.0.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "wrangler": "^4.61.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "mapbox-gl": "^3.17.0",
    "threebox-plugin": "^2.2.7"
  }
}
