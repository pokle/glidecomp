{
  "name": "glidecomp",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": "Tushar Pokle",
  "description": "Hanggliding/paragliding competition track log analysis",
  "keywords": ["hanggliding", "paragliding", "igc", "competition", "scoring", "flight-analysis"],
  "homepage": "https://glidecomp.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/pokle/glidecomp.git"
  },
  "bugs": {
    "url": "https://github.com/pokle/glidecomp/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "[ -d node_modules ] || bun install; concurrently --kill-others-on-fail -n workers,fe -c blue,cyan 'bun run dev:workers' 'bun run dev:frontend'",
    "dev:workers": "[ -d node_modules ] || bun install; bun run db:migrate && concurrently --kill-others-on-fail -n auth,comp,airscore -c blue,green,yellow 'bun run dev:auth' 'bun run dev:comp' 'bun run dev:airscore'",
    "db:migrate": "CI=true wrangler --config web/workers/auth-api/wrangler.toml d1 migrations apply taskscore-auth --local --persist-to web/.wrangler/state",
    "kill-dev": "bash web/scripts/kill-dev.sh",
    "kill-state": "bash web/scripts/kill-state.sh",
    "fresh-dev": "bash web/scripts/fresh-dev.sh",
    "dev:airscore": "bun run --filter airscore-api dev",
    "dev:frontend": "bun run --filter '@glidecomp/frontend' dev",
    "build": "bun run --filter '@glidecomp/frontend' build",
    "deploy": "bun run --filter '@glidecomp/frontend' deploy",
    "dev:auth": "bun run --filter auth-api dev",
    "deploy:worker": "bun run --filter airscore-api deploy",
    "deploy:auth": "bun run --filter auth-api deploy",
    "dev:comp": "bun run --filter competition-api dev",
    "deploy:comp": "bun run --filter competition-api deploy",
    "typecheck:comp": "bun run --filter competition-api typecheck",
    "deploy:all": "bun run deploy && bun run deploy:worker && bun run deploy:comp",
    "deployments": "wrangler pages deployment list --project-name=glidecomp --json | jq .",
    "typecheck": "tsc --noEmit",
    "typecheck:engine": "tsc --noEmit -p web/engine/tsconfig.json",
    "typecheck:worker": "bun run --filter airscore-api typecheck",
    "typecheck:auth": "bun run --filter auth-api typecheck",
    "typecheck:all": "bun run typecheck && bun run typecheck:engine && bun run typecheck:worker && bun run typecheck:auth && bun run typecheck:comp",
    "test": "bun test --cwd . ./web/engine ./web/workers/airscore-api && bun run typecheck:all",
    "test:comp": "bun run --filter competition-api test",
    "test:auth": "bun run --filter auth-api test",
    "test:all": "bun run test && bun run test:auth && bun run test:comp",
    "test:e2e": "[ -f web/workers/auth-api/.dev.vars ] || cp web/workers/auth-api/.dev.vars.example web/workers/auth-api/.dev.vars; bun run db:migrate && bunx playwright test",
    "test:e2e:ssr": "[ -f web/workers/auth-api/.dev.vars ] || cp web/workers/auth-api/.dev.vars.example web/workers/auth-api/.dev.vars; bun run db:migrate && bunx playwright test --config playwright.ssr.config.ts",
    "build-3dvis": "bun web/engine/cli/build-3dvis.ts",
    "seed": "bun web/scripts/seed-sample-comp.ts",
    "detect-events": "bun web/engine/cli/detect-events.ts",
    "get-xcontest-task": "bun web/engine/cli/get-xcontest-task.ts",
    "score-task": "bun web/engine/cli/score-task.ts",
    "bench-task": "bun web/engine/cli/bench-task.ts",
    "bench-analysis": "bun web/engine/cli/bench-analysis.ts"
  },
  "workspaces": [
    "web/engine",
    "web/frontend",
    "web/samples",
    "web/workers/*"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.5",
    "concurrently": "^9.2.4",
    "typescript": "^7.0.2",
    "wrangler": "4.112.0"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible-next": "^5.3.0",
    "mapbox-gl": "^3.26.0",
    "threebox-plugin": "^2.2.7"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "defu": "^6.1.7",
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6",
    "hono": "^4.12.31",
    "kysely": "^0.28.17",
    "postcss": "^8.5.13",
    "protocol-buffers-schema": "^3.6.1",
    "shell-quote": "^1.8.4",
    "undici": "^7.28.0",
    "vite": "^7.3.6",
    "ws": "^8.21.0"
  },
  "patchedDependencies": {
    "kysely-d1@0.4.0": "patches/kysely-d1@0.4.0.patch",
    "better-call@1.3.7": "patches/better-call@1.3.7.patch"
  }
}
