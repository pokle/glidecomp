{
  "name": "glidecomp",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "author": "Tushar Pokle",
  "description": "Hanggliding/paragliding competition track log analysis",
  "keywords": ["hanggliding", "paragliding", "igc", "competition", "scoring", "flight-analysis"],
  "homepage": "https://glidecomp.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/pokle/glidecomp.git"
  },
  "bugs": {
    "url": "https://github.com/pokle/glidecomp/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "[ -d node_modules ] || bun install; concurrently --kill-others-on-fail -n workers,fe -c blue,cyan 'bun run dev:workers' 'bun run dev:frontend'",
    "dev:workers": "[ -d node_modules ] || bun install; concurrently --kill-others-on-fail -n auth,comp,mcp,airscore -c blue,green,magenta,yellow 'bun run dev:auth' 'bun run dev:comp' 'bun run dev:mcp' 'bun run dev:airscore'",
    "kill-dev": "bash web/scripts/kill-dev.sh",
    "dev:mcp": "bun run --filter mcp-api dev",
    "dev:airscore": "bun run --filter airscore-api dev",
    "dev:frontend": "bun run --filter '@glidecomp/frontend' dev",
    "build": "bun run --filter '@glidecomp/frontend' build",
    "deploy": "bun run --filter '@glidecomp/frontend' deploy",
    "dev:auth": "bun run --filter auth-api dev",
    "deploy:worker": "bun run --filter airscore-api deploy",
    "deploy:auth": "bun run --filter auth-api deploy",
    "dev:comp": "bun run --filter competition-api dev",
    "deploy:comp": "bun run --filter competition-api deploy",
    "deploy:mcp": "bun run --filter mcp-api deploy",
    "typecheck:comp": "bun run --filter competition-api typecheck",
    "deploy:all": "bun run deploy && bun run deploy:worker && bun run deploy:comp",
    "deployments": "wrangler pages deployment list --project-name=glidecomp --json | jq .",
    "typecheck": "tsc --noEmit",
    "typecheck:engine": "tsc --noEmit -p web/engine/tsconfig.json",
    "typecheck:worker": "bun run --filter airscore-api typecheck",
    "typecheck:auth": "bun run --filter auth-api typecheck",
    "typecheck:mcp": "bun run --filter mcp-api typecheck",
    "typecheck:all": "bun run typecheck && bun run typecheck:engine && bun run typecheck:worker && bun run typecheck:auth && bun run typecheck:comp && bun run typecheck:mcp",
    "test": "bun test --cwd . ./web/engine ./web/workers/airscore-api && bun run typecheck:all",
    "test:comp": "bun run --filter competition-api test",
    "test:mcp": "bun run --filter mcp-api test",
    "test:all": "bun run test && bun run test:comp && bun run test:mcp",
    "test:e2e": "bunx playwright test",
    "detect-events": "bun web/engine/cli/detect-events.ts",
    "get-xcontest-task": "bun web/engine/cli/get-xcontest-task.ts",
    "score-task": "bun web/engine/cli/score-task.ts"
  },
  "workspaces": [
    "web/engine",
    "web/frontend",
    "web/samples",
    "web/workers/*"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.85.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "mapbox-gl": "^3.22.0",
    "threebox-plugin": "^2.2.7"
  },
  "overrides": {
    "defu": "^6.1.7",
    "hono": "^4.12.15",
    "postcss": "^8.5.10",
    "protocol-buffers-schema": "^3.6.1"
  },
  "patchedDependencies": {
    "kysely-d1@0.4.0": "patches/kysely-d1@0.4.0.patch"
  }
}