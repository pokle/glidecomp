---
/** Landing page. Ported from react/pages/Home.tsx. */
import Base from "../layouts/Base.astro";
import SiteFooter from "../components/SiteFooter.astro";

// Screenshots live in this app's own public/ dir; prefix with BASE_URL so they
// resolve under the /_static dev base and at the site root in production.
// Normalise to no trailing slash so `${base}/file` is correct either way.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="GlideComp">
  <div class="min-h-screen bg-background text-foreground p-6 bg-hills">
    <div class="max-w-2xl mx-auto flex flex-col gap-4">
      <header class="flex items-start justify-between gap-4">
        <div>
          <h1 class="font-brand text-2xl font-bold">GlideComp</h1>
          <p class="text-muted-foreground">
            Competition track log analysis for hanggliding and paragliding
          </p>
        </div>
        <!-- Plain link to the SPA sign-in page (Google + email code) — keeps
             this page zero-JS and every sign-in path funnelling through
             /signin. -->
        <a
          href="/signin"
          class="inline-flex shrink-0 items-center justify-center rounded-lg border border-transparent text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 h-8 gap-1.5 px-2.5 bg-primary text-primary-foreground hover:bg-primary/80 cursor-pointer"
        >
          Sign in
        </a>
      </header>

      <p class="text-sm text-muted-foreground">
        By signing in, you agree to our
        <a href="/legal" class="underline underline-offset-4">
          Privacy Policy &amp; Terms
        </a>
      </p>

      <p class="text-sm">
        GlideComp scores hanggliding and paragliding competitions and explains every point:
        upload IGC track logs, define tasks, and get GAP or open-distance scores with a
        step-by-step explanation any pilot can follow. Competitions and their scores are
        public — no account needed to follow along.
      </p>

      <!-- The main job for visitors who aren't signing in: find a competition. -->
      <a
        href="/comp"
        class="inline-flex items-center justify-center self-start rounded-lg border border-transparent bg-primary px-4 py-2.5 text-base font-medium whitespace-nowrap text-primary-foreground transition-all select-none hover:bg-primary/80"
      >
        Browse competitions →
      </a>

      <img
        src={`${base}/glidecomp-screenshot.png`}
        alt="GlideComp analysis interface showing a map with flight tracks and waypoints"
        class="rounded-lg border"
      />

      <SiteFooter />
    </div>
  </div>
</Base>
