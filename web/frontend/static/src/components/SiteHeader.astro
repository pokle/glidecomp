---
/**
 * Global glass menu bar for the static pages (Inscribe-style): sticky,
 * translucent, backdrop-blurred, with a right-aligned Sign in pill.
 * min-h-[60px] matches the SPA header's height so the chrome doesn't jump
 * when crossing between static and SPA pages.
 */
interface Props {
  /** Which tab to highlight, if any. */
  active?: "home" | "comp" | "flights";
}
const { active } = Astro.props;

const tab = (isActive: boolean) =>
  `text-sm font-medium transition-colors hover:text-foreground ${
    isActive ? "text-foreground" : "text-muted-foreground"
  }`;
---

<header class="sticky top-0 z-50 border-b bg-background/70 backdrop-blur-xl backdrop-saturate-150">
  <nav
    aria-label="Main"
    class="mx-auto flex min-h-[60px] w-full max-w-6xl flex-wrap items-center gap-x-6 gap-y-2 px-4 py-3"
  >
    <a href="/" class="font-brand text-base font-semibold tracking-tight">GlideComp</a>
    <a href="/comp" class={tab(active === "comp")}>Competitions</a>
    <a href="/u/me" class={`${tab(active === "flights")} max-sm:hidden`}>My Flights</a>
    <a href="/scoring" class={`${tab(false)} max-sm:hidden`}>Scoring</a>
    <div class="ml-auto">
      <button
        id="nav-signin"
        type="button"
        class="inline-flex h-8 cursor-pointer items-center justify-center rounded-full bg-primary px-4 text-sm font-medium whitespace-nowrap text-primary-foreground transition-colors select-none hover:bg-primary/85"
      >
        Sign in
      </button>
    </div>
  </nav>
</header>

<script>
  // The only interactive element in the static chrome: Google OAuth via better-auth.
  import { signInWithGoogle } from "../../../src/auth/client";
  document
    .getElementById("nav-signin")
    ?.addEventListener("click", () => void signInWithGoogle());
</script>
