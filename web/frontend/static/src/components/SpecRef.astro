---
/**
 * Link to a section of the FAI Sporting Code Section 7F (2024 edition) PDF.
 *
 * The PDF has no named anchors, so we deep-link to the page where each
 * referenced section begins using the standard `#page=N` PDF open parameter
 * (honoured by Chrome's built-in viewer and most browsers). The page numbers
 * below are the physical PDF pages of the 1st May 2024 edition.
 *
 * Usage:
 *   <SpecRef section="11.2" />                 → renders "§11.2" as a link
 *   <SpecRef section="9" label="FAI S7F §9" /> → custom link text
 */
interface Props {
  /** Spec section number, e.g. "11.2" or "8.3.1". */
  section: string;
  /** Link text. Defaults to "§{section}". */
  label?: string;
  /** Extra classes appended to the default link styling. */
  class?: string;
}

const S7F_PDF =
  "https://www.fai.org/sites/default/files/civl/documents/sporting_code_s7_f_-_xc_scoring_2024.pdf";

/** Physical PDF page where each referenced section heading begins. */
const SPEC_PAGES: Record<string, number> = {
  "2": 9, // The GAP Philosophy
  "4.2": 14, // Distance (WGS84 / FAI sphere)
  "5": 15, // Competition Parameters
  "6": 17, // Task Setting
  "6.2.3": 20, // Definition of goal
  "6.3.3": 21, // Race to goal (start gates)
  "6.4.2": 22, // Task distances
  "7": 24, // Flying a task
  "8": 25, // Task evaluation
  "8.1": 25, // Cylinder tolerance
  "8.3": 25, // Reaching a cylinder
  "8.3.1": 26, // Start time
  "8.4": 26, // Reaching (validating) a line
  "8.5.2": 27, // Goal line
  "9": 29, // Task Validity
  "9.1": 29, // Launch Validity
  "10": 31, // Points Allocation
  "11": 33, // Pilot score
  "11.1": 33, // Distance points
  "11.1.1": 33, // Difficulty calculation
  "11.2": 34, // Time points
  "11.3": 35, // Leading points
  "11.3.1": 36, // Leading coefficient
  "11.4": 38, // Arrival points
  "12.1": 40, // ESS but not goal
  "12.2": 40, // Early start
  "12.3": 41, // Stopped tasks
  "12.4": 42, // Penalties
};

const { section, label, class: extraClass = "" } = Astro.props;
const page = SPEC_PAGES[section];
const href = page ? `${S7F_PDF}#page=${page}` : S7F_PDF;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={["underline hover:text-foreground", extraClass]}
>
  {label ?? `§${section}`}
</a>
