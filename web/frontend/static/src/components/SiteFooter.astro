---
/**
 * The canonical footer for every static page, rendered full-width by
 * Base.astro after the page content: brand blurb + link columns on the
 * soft-gray section surface, with a hairline top border (Inscribe-style).
 */
const year = new Date().getFullYear();
---

<footer class="border-t bg-secondary">
  <div class="mx-auto w-full max-w-6xl px-4 py-14">
    <div class="flex flex-wrap justify-between gap-x-10 gap-y-10">
      <div class="max-w-xs">
        <a href="/" class="font-brand text-lg font-semibold tracking-tight">GlideComp</a>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          Fair, transparent scoring for hang gliding and paragliding
          competitions — every point explained.
        </p>
      </div>
      <nav aria-label="Footer" class="flex flex-wrap gap-x-14 gap-y-8">
        <div>
          <h4 class="mb-4 text-sm font-semibold">Product</h4>
          <ul class="space-y-2.5 text-sm">
            <li><a href="/comp" class="text-muted-foreground transition-colors hover:text-primary">Competitions</a></li>
            <li><a href="/scoring" class="text-muted-foreground transition-colors hover:text-primary">Scoring guide</a></li>
            <li><a href="/scoring/gap" class="text-muted-foreground transition-colors hover:text-primary">GAP scoring</a></li>
            <li><a href="/scoring/open-distance" class="text-muted-foreground transition-colors hover:text-primary">Open distance</a></li>
            <li><a href="/scoring/data-cleaning" class="text-muted-foreground transition-colors hover:text-primary">Track data cleaning</a></li>
          </ul>
        </div>
        <div>
          <h4 class="mb-4 text-sm font-semibold">Resources</h4>
          <ul class="space-y-2.5 text-sm">
            <li><a href="/about" class="text-muted-foreground transition-colors hover:text-primary">About</a></li>
            <li>
              <a
                href="https://github.com/pokle/glidecomp"
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground transition-colors hover:text-primary"
              >
                GitHub
              </a>
            </li>
            <li>
              <a
                href="https://www.youtube.com/@poklet"
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted-foreground transition-colors hover:text-primary"
              >
                YouTube
              </a>
            </li>
          </ul>
        </div>
        <div>
          <h4 class="mb-4 text-sm font-semibold">Legal</h4>
          <ul class="space-y-2.5 text-sm">
            <li><a href="/legal" class="text-muted-foreground transition-colors hover:text-primary">Privacy &amp; Terms</a></li>
          </ul>
        </div>
      </nav>
    </div>
    <div class="mt-12 border-t pt-6 text-center text-sm text-muted-foreground">
      © {year} GlideComp · Made for club comps
    </div>
  </div>
</footer>
