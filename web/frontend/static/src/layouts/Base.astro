---
/**
 * Shared shell for every static page: <head>, design-token stylesheet and the
 * OS-preference dark-mode sync (mirrors react/main.tsx's `.dark` class toggle).
 */
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";

interface Props {
  title: string;
  description?: string;
  /** Tab to underline in the global header. */
  active?: "home" | "comp" | "flights";
}

const { title, description, active } = Astro.props;
const metaDescription =
  description ??
  "GlideComp analyses hang gliding and paragliding competition tracks: tasks, GAP scoring, and per-pilot score explanations.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/icon.svg" />
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:site_name" content="GlideComp" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      // Apply the Light/Dark/Auto colour-scheme preference via a `.dark` class on
      // <html>, matching the SPA (localStorage `glidecomp-theme`; missing = auto,
      // which follows the OS). Inline + in <head> so it runs before paint (no flash).
      (function () {
        var q = window.matchMedia("(prefers-color-scheme: dark)");
        var sync = function () {
          var pref = localStorage.getItem("glidecomp-theme");
          if (pref !== "light" && pref !== "dark" && pref !== "auto") pref = "auto";
          document.documentElement.classList.toggle(
            "dark",
            pref === "dark" || (pref === "auto" && q.matches)
          );
        };
        sync();
        q.addEventListener("change", sync);
        window.addEventListener("storage", function (e) {
          if (e.key === "glidecomp-theme") sync();
        });
      })();
    </script>
  </head>
  <body>
    <SiteHeader active={active} />
    <slot />
  </body>
</html>
