{
  "name": "@glidecomp/frontend",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,astro -c cyan,magenta \"vite\" \"ASTRO_BASE=/_static astro dev --root static\"",
    "build": "vite build && bun run build:ssr && bun run build:static",
    "build:ssr": "vite build --config vite.ssr.config.ts",
    "build:static": "astro build --root static && cp -R static/dist/. dist/",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler pages deploy dist --project-name=glidecomp",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@astrojs/mdx": "^6",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@types/tabulator-tables": "^6.3.6",
    "@vitejs/plugin-react": "^5.1.4",
    "astro": "^6.4.8",
    "jsdom": "^25.0.1",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10",
    "wrangler": "4.110.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@glidecomp/engine": "workspace:*",
    "@glidecomp/samples": "workspace:*",
    "@types/three": "^0.185.1",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.29",
    "katex": "^0.17.0",
    "leaflet": "2.0.0-alpha.1",
    "lucide-react": "^1.24.0",
    "mapbox-gl": "^3.26.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "^7.9.5",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tabulator-tables": "^6.5.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "threebox-plugin": "^2.2.7",
    "tw-animate-css": "^1.4.0"
  }
}