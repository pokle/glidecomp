{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@glidecomp/engine": ["./web/engine/src/index.ts"]
    },
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "@cloudflare/workers-types",
      "@types/node",
      "bun"
    ]
  },
  "include": [
    "web/engine/src/**/*",
    "web/frontend/src/**/*",
    "web/workers/**/*",
    "web/engine/tests/**/*",
    "web/scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules",
    "web/workers/competition-api/test",
    "web/workers/auth-api/src",
    "web/workers/auth-api/test",
    "web/workers/mcp-api/src"
  ]
}